PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kitools

MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_USER=postgres
MAIN_DB_PASSWORD=postgres
MAIN_DB_NAME=kitools
MAIN_DB_MIGRATIONS_RUN=false

TOOL_DB_HOST=localhost
TOOL_DB_PORT=5432
TOOL_DB_USER=postgres
TOOL_DB_PASSWORD=postgres
TOOL_DB_NAME=kitools
TOOL_DB_MIGRATIONS_RUN=false

AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=5433
AUDIT_DB_USER=postgres
AUDIT_DB_PASSWORD=postgres
AUDIT_DB_NAME=kitools_audit
AUDIT_DB_MIGRATIONS_RUN=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_ACCESS_SECRET=access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_LIMIT=120
# Chặn gửi trùng (cùng hash body+path+method+ip) trong cửa sổ này (giây). Upload multipart không áp dụng (body chưa parse ở interceptor).
ANTI_SPAM_TTL_SECONDS=6

UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=500000000

# Chunk upload cho video lớn (5GB+). Chunks lưu tạm tại UPLOAD_DIR/_chunks/<uploadId>/
# CHUNK_UPLOAD_DIR= (mặc định dùng UPLOAD_DIR)
CHUNK_UPLOAD_MAX_FILE_BYTES=10737418240

# (Tùy chọn) Thư mục tuyệt đối có quyền ghi cho output TTS / clone / preview audio (con: audio-tts, audio-clone, audio-previews).
# Dùng khi process không mkdir được trong repo (EACCES). Ví dụ: AUDIO_DATA_ROOT=/var/tmp/kitools-audio
# AUDIO_DATA_ROOT=

# OmniVoice TTS — seed cố định, khớp auto_vietsub_pro. none = random.
OMNIVOICE_SEED=42

TRANSLATE_PYTHON_BIN=python
TRANSLATE_PYTHON_SCRIPT=tools/video-pipeline/auto_vietsub_pro.py
TRANSLATE_CMD_TIMEOUT_MS=1200000
# Kết quả cuối (mp4/srt) — logic cũ, vd. ổ Windows qua WSL
TRANSLATE_WORK_ROOT=/mnt/c/Users/haikh/Videos/VideoVietsub/videos
# Workspace xử lý (log, VSE temp) — WSL dev: đặt /home/... (khác WORK_ROOT)
# TRANSLATE_WORK_STAGING_ROOT=/home/haikhuong/sources/KiTLabs-BE/tools/video-pipeline/workspace

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Gemini — Videos AI Task (Key Normal) + Translate Step2 standard pool.
# Một key: AIzaSy...
# Nhiều key (round-robin): key1,key2  |  key1;key2  |  key1|key2  |  ["key1","key2"]
GEMINI_API_KEY=AIzaSyB5p2t9XWBMzqIJ0Pm59r8NsvZJpKDXuNc

# Key VIP — Videos AI Task (Key VIP), Translate --gemini-key-tier vip, YouTube AI.
# Cùng format nhiều key như GEMINI_API_KEY.
# Ví dụ: GEMINI_API_KEY_VIP=key1,key2,key3
GEMINI_API_KEY_VIP=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/youtube/auth/google/callback
FRONTEND_URL=http://localhost:3001
YOUTUBE_AI_MODEL=gemini-2.5-pro
YOUTUBE_AI_TEMPERATURE=0.2
TRENDS_PYTHON_BIN=python
TRENDS_PYTHON_SCRIPT=tools/trends/fetch_trends.py

# FLUX.1 Schnell — video workflow Image node (tools/video-pipeline/video_image_flux.py)
IMAGE_PYTHON_BIN=python
IMAGE_PYTHON_SCRIPT=tools/video-pipeline/video_image_flux.py
VIDEOS_IMAGE_CMD_TIMEOUT_MS=900000
FLUX_MODEL_ID=black-forest-labs/FLUX.1-schnell
# Card 12GB: FLUX_OFFLOAD=auto (mặc định) → model_cpu_offload, peak VRAM ~6–10 GiB.
# sequential: VRAM rất thấp (~1–2 GiB) nhưng chậm. model: cân bằng tốc độ/VRAM. cuda: full GPU (cần ≥24GB VRAM).
FLUX_DEVICE_MAP=cuda:0
FLUX_DTYPE=float16
FLUX_OFFLOAD=auto
# FLUX_OFFLOAD=sequential
# FLUX_OFFLOAD=model
# FLUX_OFFLOAD=cuda
# FLUX_MAX_LONG_EDGE=896
# FLUX cache: tools/video-pipeline/cache/flux (~23GiB, tải 1 lần; lần sau chỉ đọc disk)
# FLUX_LOCAL_FILES_ONLY=1
# FLUX_ALLOW_CPU=1
FLUX_NUM_INFERENCE_STEPS=4
FLUX_GUIDANCE_SCALE=0
FLUX_MAX_SEQUENCE_LENGTH=256
FLUX_SEED=42
# Hugging Face Read token — dùng chung OmniVoice + FLUX (Agree FLUX.1-schnell trên Hub)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KITLABS_PYTHON_CACHE_DIR=/var/cache/kitools-python
# VIDEO_IMAGES_DATA_ROOT=/var/tmp/kitools-video-images