{
  "name": "kitools-be",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "migration:run:main": "typeorm-ts-node-commonjs -d src/database/data-source.main.ts migration:run",
    "migration:revert:main": "typeorm-ts-node-commonjs -d src/database/data-source.main.ts migration:revert",
    "migration:generate:main": "typeorm-ts-node-commonjs -d src/database/data-source.main.ts migration:generate src/database/migrations/main/AutoMainMigration",
    "migration:run:tool": "typeorm-ts-node-commonjs -d src/database/data-source.tool.ts migration:run",
    "migration:revert:tool": "typeorm-ts-node-commonjs -d src/database/data-source.tool.ts migration:revert",
    "migration:generate:tool": "typeorm-ts-node-commonjs -d src/database/data-source.tool.ts migration:generate src/database/migrations/main/AutoToolMigration",
    "migration:run:audit": "typeorm-ts-node-commonjs -d src/database/data-source.audit.ts migration:run",
    "migration:revert:audit": "typeorm-ts-node-commonjs -d src/database/data-source.audit.ts migration:revert",
    "migration:generate:audit": "typeorm-ts-node-commonjs -d src/database/data-source.audit.ts migration:generate src/database/migrations/audit/AutoAuditMigration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.16",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
